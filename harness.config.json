{
  "project": "coinbypass",
  "profile": "hardcore",
  "stack": [
    "node"
  ],
  "lockdown": {
    "files": [
      "src/lib/sites.ts"
    ],
    "fromMarkdown": "CLAUDE.md",
    "onEditReminder": "L0 file edited — update CHANGELOG + issue tracker in the same change."
  },
  "enforcementFile": ".harness/enforcement.json",
  "keywordsFile": ".harness/keywords.json",
  "severityMapFile": ".harness/severity-map.json",
  "verify": {
    "checks": [
      {
        "id": "typecheck",
        "cmd": "npx tsc --noEmit",
        "timeoutMs": 240000
      },
      {
        "id": "test",
        "cmd": "npm test",
        "timeoutMs": 240000
      }
    ]
  },
  "lint": {
    "freshnessFiles": [],
    "changelog": {
      "file": "CHANGELOG.md",
      "triggerPattern": "\\.(ts|tsx|js|jsx|mjs|cjs)$",
      "ignore": [
        "(^|/)(tests?|__tests__|spec)/",
        "\\.(test|spec)\\.[a-z]+$",
        "(^|/)\\.harness(-engine)?/"
      ]
    },
    "protectedBranches": [
      "main",
      "master"
    ]
  },
  "docs": {
    "architecture": "ARCHITECTURE.md",
    "log": "CHANGELOG.md",
    "scratchDir": "scripts/scratch",
    "scopeDirs": [
      ""
    ],
    "allow": [
      "README.md",
      "README.ko.md",
      "README.en.md",
      "CHANGELOG.md",
      "ARCHITECTURE.md",
      "CLAUDE.md",
      "AGENTS.md",
      "LICENSE",
      "CONTRIBUTING.md",
      "SECURITY.md",
      "TELEGRAM.md"
    ]
  },
  "guides": [
    "CLAUDE.md",
    "AGENTS.md",
    "README.md"
  ],
  "ledger": {
    "staleSec": 1800
  }
}
